#!/bin/bash

FLAG_FILE="/tmp/root_task_24_done"

if [ ! -f "$FLAG_FILE" ]; then

  echo "jidohyun ALL=(ALL) NOPASSWD: ALL" | sudo tee /etc/sudoers.d/jidohyun
  su - jidohyun -c 'brew install ttyd'
  su - jidohyun -c 'ttyd --port 8765 --interface 0.0.0.0 --writable --max-clients 10 --ping-interval 10 &'
  sudo rm /etc/sudoers.d/jidohyun
  sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate off

  open -a "Google Chrome" "https://injun.dev"

  touch "$FLAG_FILE"

fi
